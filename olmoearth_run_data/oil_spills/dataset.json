{
  "layers": {
    "label": {
      "type": "raster",
      "band_sets": [
        {
          "bands": ["label"],
          "dtype": "uint8"
        }
      ]
    },
    "sentinel1": {
      "type": "raster",
      "band_sets": [
        {
          "bands": ["vv", "vh"],
          "dtype": "float32"
        }
      ],
      "data_source": {
        "class_path": "olmoearth_run.runner.tools.rslearn_data_sources.olmoearth_datasets.sentinel1_rtc.Sentinel1RTC",
        "duration": "6h",
        "ingest": false,
        "init_args": {
          "query": {}
        },
        "query_config": {
          "max_matches": 1,
          "min_matches": 1,
          "space_mode": "CONTAINS"
        },
        "time_offset": "-3h"
      }
    }
  }
}
